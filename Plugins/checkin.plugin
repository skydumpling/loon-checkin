#!name=论坛每日签到
#!desc=PCBeta / cnCalc / UIWOW 独立脚本，Cookie 获取项可单独禁用
#!author=skydumpling
#!homepage=https://github.com/skydumpling/loon-checkin

[MITM]
hostname = %APPEND% i.pcbeta.com, www.cncalc.org, uiwow.com, www.uiwow.com

[Script]
# 获取 Cookie：成功后建议禁用这 3 条，降低 MITM 和耗电。
http-request ^https:\/\/i\.pcbeta\.com\/home\.php\?mod=task tag=PCBeta获取Cookie, script-path=https://raw.githubusercontent.com/skydumpling/loon-checkin/refs/heads/main/Tasks/pcbeta.js, requires-body=false, timeout=20, enable=true
http-request ^https:\/\/www\.cncalc\.org\/(dsu_paulsign-sign\.html|plugin\.php\?id=dsu_paulsign:sign) tag=cnCalc获取Cookie, script-path=https://raw.githubusercontent.com/skydumpling/loon-checkin/refs/heads/main/Tasks/cncalc.js, requires-body=false, timeout=20, enable=true
http-request ^https:\/\/(www\.)?uiwow\.com\/ tag=UIWOW获取Cookie, script-path=https://raw.githubusercontent.com/skydumpling/loon-checkin/refs/heads/main/Tasks/uiwow.js, requires-body=false, timeout=20, enable=true

# 每天 09:00 签到。
cron "0 9 * * *" script-path=https://raw.githubusercontent.com/skydumpling/loon-checkin/refs/heads/main/Tasks/pcbeta.js, timeout=60, tag=PCBeta签到, enable=true
cron "0 9 * * *" script-path=https://raw.githubusercontent.com/skydumpling/loon-checkin/refs/heads/main/Tasks/cncalc.js, timeout=60, tag=cnCalc签到, argument="mood=kx&saying=%E7%AD%BE%E5%88%B0", enable=true
cron "0 9 * * *" script-path=https://raw.githubusercontent.com/skydumpling/loon-checkin/refs/heads/main/Tasks/uiwow.js, timeout=60, tag=UIWOW签到, argument="mood=kx&saying=%E7%AD%BE%E5%88%B0", enable=true
